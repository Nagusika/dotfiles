# Versions épinglées des binaires tier-2 (musl statiques, posés dans ~/.local/bin).
# Sourcé par les modules qui appellent install_bin.
# sha256 = checksum réel de l'asset upstream de la version épinglée (vérifié fatal).

# --- prompt (E2) ---
STARSHIP_VERSION=1.26.0
STARSHIP_SHA256_X86_64=b7c232b0e8249d8e55a40beb79c5c43a7d370f3f9408bd215deb0170daeaadf3

# --- cli (E3, à venir) ---
# EZA_VERSION=...
# ZOXIDE_VERSION=...
# FZF_VERSION=...  (présent dans EPEL 0.58 -> peut rester tier-1)
